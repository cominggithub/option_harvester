{
  "manifest_version": 3,
  "name": "IB → option_harvester sync",
  "version": "0.1.0",
  "description": "Captures positions + pending orders from the logged-in IB portal and sends them to the option_harvester backend.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://*.interactivebrokers.com/*",
    "https://*.ibkr.com/*",
    "http://114.33.62.221:19210/*",
    "http://114.33.62.221:19211/*",
    "http://localhost:19210/*",
    "http://localhost:19211/*"
  ],
  "background": { "service_worker": "background.js" },
  "action": { "default_popup": "popup.html", "default_title": "IB sync" },
  "content_scripts": [
    {
      "matches": ["https://*.interactivebrokers.com/*", "https://*.ibkr.com/*"],
      "js": ["hook.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://*.interactivebrokers.com/*", "https://*.ibkr.com/*"],
      "js": ["relay.js"],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ]
}

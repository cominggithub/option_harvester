// option_harvester — owns ONLY the option_harvest_* tables (see CLAUDE.md).
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Sticky correct-conid registry — overrides the /trsrv-resolved `Security.conid`
/// when that pick is wrong (a naked book rarely holds the underlying stock, so the
/// "prefer the held position's conid" rule can't help, and IB's /trsrv/stocks can
/// resolve a symbol to the wrong listing — e.g. SMCI/DOW). Two sources:
///   • "manual"    — user-pinned to a known-correct conid (never auto-overwritten).
///   • "ib-option" — derived from a HELD option leg's underlying (undConid), which
///                   IB reports authoritatively (the naked-strategy analogue of the
///                   held-stock-conid fix).
/// Writing a pin also mirrors the conid into Security.conid so every consumer uses
/// it; the periodic full re-resolve (POST /api/securities/conids) SKIPS pinned
/// tickers so the correction sticks. Consumed by buildOhPushLists (src/lib/ohpush.ts).
model SecurityConid {
  ticker String   @id
  conid  String
  source String   @default("manual") // "manual" | "ib-option"
  note   String?
  at     DateTime @updatedAt

  @@map("option_harvest_security_conids")
}

/// Daily snapshot of the OH-watchlist screen drivers, one row per (date, ticker),
/// written by the daily ingest (scripts/snapshot-oh.ts). It records the exact inputs
/// each OH list's membership rule depends on, so the change log (src/lib/ohhistory.ts)
/// can diff consecutive days per list (NC/NCcan/Cpos/Ppos/RED) AND explain *why* a
/// name was added/removed (which predicate input flipped — e.g. IV crossed 40, a
/// position opened, |Δ| rose past 0.30). OH lists are otherwise computed-only (never
/// stored), so this is the sole membership history. Upserted per day (last run wins).
model OhScreenSnapshot {
  date           DateTime @db.Date
  ticker         String
  nc             Boolean  @default(false) // passes the naked-call screen (isNcTarget)
  held           Boolean  @default(false) // user holds this underlying
  posCall        Int      @default(0)     // net call contracts held
  posPut         Int      @default(0)     // net put contracts held
  maxOptAbsDelta Decimal? @map("max_opt_abs_delta") // max |Δ| across held option legs
  volume         BigInt? // the NC-criteria inputs, kept for reason strings:
  price          Decimal?
  weeklyBuckets  Int?     @map("weekly_buckets")
  ivPct          Decimal? @map("iv_pct")
  trendM1        String?  @map("trend_m1") // up|down|sideways
  trendM3        String?  @map("trend_m3")
  trendM6        String?  @map("trend_m6")
  at             DateTime @updatedAt

  @@id([date, ticker])
  @@index([date])
  @@map("option_harvest_oh_screen_snapshots")
}

/// Static metadata for each S&P 500 constituent / large ETF.
model Security {
  ticker      String   @id
  name        String
  description String?
  sector      String   @default("Unclassified")
  subIndustry String?  @map("sub_industry")
  type        String   @default("stock") // "stock" | "etf"
  conid       String?  // IB contract id for the underlying (backfilled via /trsrv/stocks)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  quote   Quote?
  mark    Mark?
  trend   Trend?
  ccScore CcScore?

  @@index([sector])
  @@map("option_harvest_securities")
}

/// Daily OHLCV bars (our own dataset; ~14 months kept for 1y trend analysis).
model DailyPrice {
  ticker String
  date   DateTime @db.Date
  open   Decimal?
  high   Decimal?
  low    Decimal?
  close  Decimal?
  volume BigInt?

  @@id([ticker, date])
  @@index([ticker, date])
  @@map("option_harvest_daily_prices")
}

/// Per-ticker multi-window trend summary, recomputed daily from DailyPrice.
model Trend {
  ticker      String   @id
  sma50       Decimal? // 50-trading-day simple moving average of close
  sma200      Decimal? // 200-trading-day SMA (null if < 200 bars)
  pctFromHigh Decimal? @map("pct_from_high") // % vs trailing 52-week high (<= 0)
  // { m1,m3,m6,y1: { ret, slopePct, r2, label: up|down|sideways } }
  windows     Json?
  bars        Int      @default(0) // bars used in the computation
  computedAt  DateTime @updatedAt @map("computed_at")

  security Security @relation(fields: [ticker], references: [ticker], onDelete: Cascade)

  @@map("option_harvest_trends")
}

/// User marks: starred favorite and/or option (covered-call) target.
model Mark {
  ticker    String   @id
  favorite  Boolean  @default(false)
  target    Boolean  @default(false)
  rating    Int      @default(0) // option-target conviction: +1..+3 call, -1..-3 put, 0 = unrated
  labels    String[] @default([]) // user tags (nc/np/low vol/…); catalog = seeds ∪ in-use, no separate table
  updatedAt DateTime @updatedAt @map("updated_at")

  security Security @relation(fields: [ticker], references: [ticker], onDelete: Cascade)

  @@map("option_harvest_marks")
}

/// Latest market snapshot per security (price, market cap, volume).
model Quote {
  ticker    String   @id
  price     Decimal?
  marketCap BigInt?  @map("market_cap")
  volume    BigInt?
  changePct Decimal? @map("change_pct")
  ivPct     Decimal? @map("iv_pct") // front-month ATM implied volatility, %
  ivDte     Int?     @map("iv_dte") // days-to-expiry used for the IV calc
  weeklyBuckets Int?  @map("weekly_buckets") // of {0,7,14,21,28,35} DTE expiries available (0-6)
  nextEarnings DateTime? @map("next_earnings") // next earnings date (gap-risk gate); null for ETFs
  // ATM ~30-DTE option liquidity. strike/mid/expiries refresh nightly (mid from
  // last trade since the US market is closed at ingest); bid/ask/spread come from
  // the intraday spread fetch (scripts/ingest-spreads.ts) during US hours.
  atmStrike   Decimal?  @map("atm_strike")
  atmMid      Decimal?  @map("atm_mid")       // ATM call mid (bid/ask mid if live, else last)
  atmBid      Decimal?  @map("atm_bid")
  atmAsk      Decimal?  @map("atm_ask")
  atmSpreadPct Decimal? @map("atm_spread_pct") // (ask-bid)/mid, 0-1; null when no live quote
  spreadAt    DateTime? @map("spread_at")      // when bid/ask were last captured live
  expiries    Json?                            // near-term ladder: [{d:"YYYY-MM-DD",dte:n}] within ~63 DTE
  // Long-term fundamentals (from the same quoteSummary call as description/earnings).
  trailingPe      Decimal? @map("trailing_pe")
  forwardPe       Decimal? @map("forward_pe")
  pegRatio        Decimal? @map("peg_ratio")
  dividendYield   Decimal? @map("dividend_yield")  // fraction (0.0052 = 0.52%)
  beta            Decimal?
  week52Low       Decimal? @map("week52_low")
  week52High      Decimal? @map("week52_high")
  profitMargins   Decimal? @map("profit_margins")  // fraction
  analystRec      String?  @map("analyst_rec")      // e.g. "strong_buy"
  targetMeanPrice Decimal? @map("target_mean_price")
  currency  String   @default("USD")
  asOf      DateTime @default(now()) @map("as_of")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Parallel IB-sourced option snapshot (from the Chrome extension, /api/options).
  // Kept separate from the Yahoo-sourced fields above so IB vs Yahoo can be compared
  // before the screens switch source. Populated for the ~30-DTE ATM call; live
  // bid/ask/IV only meaningful during US market hours.
  ibPrice        Decimal?  @map("ib_price")        // underlying last (spot) from IB
  ibIvPct        Decimal?  @map("ib_iv_pct")       // ATM call implied vol %, IB-computed
  ibIvDte        Int?      @map("ib_iv_dte")        // DTE of the chosen expiry
  ibExpiry       String?   @map("ib_expiry")        // chosen option expiry, YYYY-MM-DD
  ibAtmStrike    Decimal?  @map("ib_atm_strike")
  ibAtmBid       Decimal?  @map("ib_atm_bid")
  ibAtmAsk       Decimal?  @map("ib_atm_ask")
  ibAtmMid       Decimal?  @map("ib_atm_mid")
  ibAtmSpreadPct Decimal?  @map("ib_atm_spread_pct") // (ask-bid)/mid, 0-1
  ibDelta        Decimal?  @map("ib_delta")
  ibAt           DateTime? @map("ib_at")             // when the IB snapshot was captured

  security Security @relation(fields: [ticker], references: [ticker], onDelete: Cascade)

  @@map("option_harvest_quotes")
}

/// User's uploaded IB positions — a snapshot, replaced wholesale on each upload
/// (POST /api/positions). Best-effort parse of an IB CSV export; `raw` keeps the
/// original row so nothing is lost. Cross-linked to the dashboard by `symbol`.
model Position {
  id          Int      @id @default(autoincrement())
  symbol      String // underlying ticker (first token of the IB symbol, upper-cased)
  description String?
  secType     String?  @map("sec_type")
  quantity    Decimal?
  avgCost     Decimal? @map("avg_cost")
  marketValue Decimal? @map("market_value")
  currency    String?
  right       String? // option right: "C" | "P"; null for spot
  strike      Decimal?
  expiry      String? // option expiry, YYYY-MM-DD
  raw         Json? // the original parsed CSV row, by header name
  uploadId    Int?     @map("upload_id") // which PositionUpload produced this row
  uploadedAt  DateTime @default(now()) @map("uploaded_at")

  @@index([symbol])
  @@map("option_harvest_positions")
}

/// Live working/pending orders pulled from the IB portal (via the Chrome
/// extension). Replaced wholesale on each sync — pending orders are ephemeral, so
/// unlike positions there's no raw-file audit table to re-import from.
model Order {
  id          Int      @id @default(autoincrement())
  orderId     String?  @map("order_id") // IB order id, for reference/dedup
  symbol      String // underlying ticker
  description String? // full instrument when it's an option
  secType     String?  @map("sec_type")
  action      String? // "BUY" | "SELL"
  quantity    Decimal?
  orderType   String?  @map("order_type") // "LMT" | "MKT" | "STP" | …
  limitPrice  Decimal? @map("limit_price")
  auxPrice    Decimal? @map("aux_price") // stop / trigger price
  tif         String? // time-in-force: "DAY" | "GTC" | …
  status      String? // "Submitted" | "PreSubmitted" | …
  right       String? // option right: "C" | "P"; null for spot
  strike      Decimal?
  expiry      String? // YYYY-MM-DD
  currency    String?
  raw         Json? // the original portal record
  uploadedAt  DateTime @default(now()) @map("uploaded_at")

  @@index([symbol])
  @@map("option_harvest_orders")
}

/// Every uploaded IB CSV is kept here (the raw file), so the upload history
/// survives and a file can be re-imported. The current positions are the parse
/// of the most recent upload.
model PositionUpload {
  id         Int      @id @default(autoincrement())
  filename   String?
  content    String   @db.Text // the raw CSV
  rowCount   Int      @map("row_count") // positions parsed from it
  uploadedAt DateTime @default(now()) @map("uploaded_at")

  @@map("option_harvest_position_uploads")
}

/// User's uploaded IB transaction history (trades Flex Query, e.g.
/// U<acct>.TRANSACTIONS.YTD) — replaced wholesale on each upload. The realized-P/L
/// source. `raw` keeps the original row so nothing is lost across format variants.
model Transaction {
  id          Int      @id @default(autoincrement())
  symbol      String // underlying ticker
  description String? // full instrument when it's an option
  assetClass  String?  @map("asset_class")
  tradeDate   String?  @map("trade_date") // YYYY-MM-DD
  right       String? // option right: "C" | "P"; null for spot
  strike      Decimal?
  expiry      String?
  quantity    Decimal?
  price       Decimal?
  proceeds    Decimal?
  commission  Decimal?
  realizedPnl Decimal? @map("realized_pnl")
  currency    String?
  raw         Json?
  uploadId    Int?     @map("upload_id")
  uploadedAt  DateTime @default(now()) @map("uploaded_at")

  @@index([symbol])
  @@index([tradeDate])
  @@map("option_harvest_transactions")
}

/// Every uploaded transactions file is kept (raw) for history + re-import.
model TransactionUpload {
  id         Int      @id @default(autoincrement())
  filename   String?
  content    String   @db.Text
  rowCount   Int      @map("row_count")
  uploadedAt DateTime @default(now()) @map("uploaded_at")

  @@map("option_harvest_transaction_uploads")
}

/// Daily IV snapshot history — appended every ingest so we can compute IV
/// rank/percentile and (later) a premium-aware backtest. We have no other source
/// of historical IV: only today's snapshot lives in Quote, so this table is the
/// only way the IV time series accumulates. Keyed by ingest date, idempotent.
model IvHistory {
  ticker        String
  date          DateTime @db.Date
  ivPct         Decimal? @map("iv_pct")
  ivDte         Int?     @map("iv_dte")
  weeklyBuckets Int?     @map("weekly_buckets")
  price         Decimal?
  createdAt     DateTime @default(now()) @map("created_at")

  @@id([ticker, date])
  @@index([ticker, date])
  @@map("option_harvest_iv_history")
}

/// Δ0.30 covered-call model output, recomputed daily by scripts/predict-cc.py.
/// Stored (not derived at read time) because it must match the frozen prediction
/// archive exactly — see docs/cc-target-strategy.md §8. The web reads `eScore`.
model CcScore {
  ticker    String   @id
  entryDate String   @map("entry_date") // bar date the score was computed on (YYYY-MM-DD)
  iv        Decimal? // implied vol used, %
  rv        Decimal? // trailing-20d realized vol, %
  ivRv      Decimal? @map("iv_rv") // IV / RV ratio — the core edge dial
  strike    Decimal? // Δ0.30 call strike
  otm       Decimal? // strike vs spot, %
  premYield Decimal? @map("prem_yield") // premium collected, % of spot
  pAssign   Decimal? @map("p_assign") // P(finish > strike), %, calibrated
  pStop     Decimal? @map("p_stop") // P(touch 2.5x-premium stop), %, calibrated
  eScore    Decimal? @map("e_score") // expected capture E = yield*(1-2.5*pStop), % of spot
  isTarget  Boolean  @default(false) @map("is_target") // passes the doctrine filter (downtrend ∩ liquid ∩ $20-150 ∩ no earnings in window)
  eventFlag Boolean  @default(false) @map("event_flag") // earnings report falls inside the DTE window (gap risk)
  computedAt DateTime @updatedAt @map("computed_at")

  security Security @relation(fields: [ticker], references: [ticker], onDelete: Cascade)

  @@map("option_harvest_cc_scores")
}

/// User's IB watchlists, synced from the portal via the Chrome extension. One row
/// per (watchlist, instrument); replaced wholesale on each sync (like Order — the
/// lists are ephemeral, no raw-file audit table). Lets the dashboard show which
/// curated lists a ticker belongs to. `raw` keeps the original portal instrument.
model WatchlistItem {
  id            Int      @id @default(autoincrement())
  watchlistId   String   @map("watchlist_id")   // IB watchlist id ("113", "NAMED_CRYPTO", …)
  watchlistName String   @map("watchlist_name") // IB list name ("AI", "Doom", …)
  position      Int      @default(0)            // order of the instrument within the list
  conid         String?                          // IB contract id
  ticker        String?                          // symbol, upper-cased; null for non-symbol instruments
  name          String?                          // instrument name / full name
  secType       String?  @map("sec_type")        // "STK" | "ETF" | …
  assetClass    String?  @map("asset_class")
  raw           Json?
  syncedAt      DateTime @default(now()) @map("synced_at")

  @@index([ticker])
  @@index([watchlistId])
  @@map("option_harvest_watchlist")
}

/// Audit log for each ingestion run.
model IngestRun {
  id          Int       @id @default(autoincrement())
  startedAt   DateTime  @default(now()) @map("started_at")
  finishedAt  DateTime? @map("finished_at")
  status      String    @default("running") // running | success | failed
  tickersOk   Int       @default(0) @map("tickers_ok")
  tickersFail Int       @default(0) @map("tickers_fail")
  notes       String?

  @@map("option_harvest_ingest_runs")
}

/// Per-contract option greeks (delta/gamma/theta/vega + IV), keyed by IB conid.
/// Synced from the IB Client-Portal market-data snapshot by the Chrome extension
/// (fields 7308/7309/7310/7311/7283) and joined to held positions by conid at read
/// time. Kept in its own table so it survives the full-replace positions re-import.
model OptionGreek {
  conid String   @id
  delta Decimal?
  gamma Decimal?
  theta Decimal?
  vega  Decimal?
  iv    Decimal? // implied vol %, IB-computed (field 7283)
  at    DateTime @default(now()) // when the snapshot was captured

  @@map("option_harvest_option_greeks")
}

/// Exact per-position margin from IB, computed by the Chrome extension via the
/// Client-Portal what-if order endpoint (POST /iserver/account/{acct}/orders/whatif
/// on a CLOSING order for the held contract): the position's requirement =
/// maintenance.current − maintenance.after. Keyed by conid so it survives the
/// full-replace positions re-import; joined to held legs at read time.
model PositionMargin {
  conid       String   @id
  maintMargin Decimal? @map("maint_margin") // maintenance margin the position ties up
  initMargin  Decimal? @map("init_margin") // initial margin the position ties up
  currency    String? // account base currency of the figures
  at          DateTime @default(now()) // when the what-if was captured

  @@map("option_harvest_position_margin")
}

/// Audit log for each IB→web sync run (Chrome extension). One row per Sync (manual
/// or auto); the extension posts its run summary to POST /api/sync-log at the end.
/// Powers the /sync page's run history. `raw` keeps the full summary object.
model SyncRun {
  id         Int      @id @default(autoincrement())
  at         DateTime @default(now())
  source     String   @default("manual") // "manual" | "auto"
  acct       String? // IB account the sync ran against
  positions  Int? // positions upserted
  orders     Int? // working orders replaced
  trades     Int? // executions added to transactions
  watchlists Int? // IB lists pulled
  greeks     Int? // contracts that returned greeks
  margin     Int? // contracts that returned a what-if margin
  ohPush     Int?     @map("oh_push") // OH lists pushed back to IB
  error      String? // top-level error, if the run failed
  raw        Json? // full summary object from the extension

  @@index([at])
  @@map("option_harvest_sync_runs")
}

/// Read-back verification of the OH→IB watchlist push. After pushing the "OH:*"
/// lists to IB, the Chrome extension re-fetches them from IB (`/iserver/watchlist`)
/// and POSTs the returned conids to /api/oh-verify, which diffs them against the
/// intended payload (`buildOhPushLists`, the same source `oh-watchlists` GET uses).
/// This closes the loop that eyeballing OH:RED in the IB app used to cover — the
/// OH:* lists are deliberately excluded from the normal watchlist sync (§4d), so
/// this dedicated path is the only programmatic window into what IB actually stored.
/// One row per verification run; powers the /sync page's OH-verify panel.
model OhVerify {
  id         Int      @id @default(autoincrement())
  at         DateTime @default(now())
  lists      Int? // OH lists read back from IB
  matched    Int? // conids that matched the intended payload
  mismatched Int? // conids missing (intended, not stored) + extra (stored, not intended)
  ok         Boolean  @default(false) // every list matched exactly (no missing/extra)
  detail     Json? // per-list diff: [{ key, name, intended, actual, missing, extra, ok }]
  error      String? // top-level error, if verification failed
  raw        Json? // the payload the extension posted (lists + conids from IB)

  @@index([at])
  @@map("option_harvest_oh_verify")
}

/// Daily IB account-balance snapshot, pulled by the Chrome extension from the
/// Client-Portal `/portfolio/{acct}/summary` endpoint. One row per calendar day
/// (upserted — the last sync of the day wins), so the series accumulates a daily
/// history of cash / NLV / margin. Stock vs option market value is computed from
/// our synced positions (the summary doesn't split by asset class). `raw` keeps
/// the full summary object.
model AccountBalance {
  date               DateTime @id @db.Date // one snapshot per day (base currency)
  netLiquidation     Decimal? @map("net_liquidation")
  totalCash          Decimal? @map("total_cash")
  settledCash        Decimal? @map("settled_cash")
  availableFunds     Decimal? @map("available_funds")
  excessLiquidity    Decimal? @map("excess_liquidity")
  buyingPower        Decimal? @map("buying_power")
  grossPositionValue Decimal? @map("gross_position_value")
  equityWithLoan     Decimal? @map("equity_with_loan")
  regtEquity         Decimal? @map("regt_equity")
  regtMargin         Decimal? @map("regt_margin")
  initMargin         Decimal? @map("init_margin") // current initial margin requirement
  maintMargin        Decimal? @map("maint_margin") // current maintenance margin requirement
  fullInitMargin     Decimal? @map("full_init_margin")
  fullMaintMargin    Decimal? @map("full_maint_margin")
  cushion            Decimal? // excess liquidity / NLV, 0-1
  stockValue         Decimal? @map("stock_value") // Σ market value of stock legs (from positions)
  optionValue        Decimal? @map("option_value") // Σ market value of option legs (from positions)
  currency           String? // account base currency
  acct               String? // IB account id
  raw                Json? // full /portfolio/{acct}/summary object
  at                 DateTime @updatedAt // last update for the day

  @@map("option_harvest_account_balances")
}
